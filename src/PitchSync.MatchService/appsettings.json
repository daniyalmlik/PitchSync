{
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://localhost:5000", "https://pitchsyncweb.z1.web.core.windows.net" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1434;Database=PitchSync_MatchDb;User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "PitchSync",
    "Audience": "PitchSync",
    "ExpiryMinutes": 480
  }
}
